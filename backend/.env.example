# Server Configuration
NODE_ENV=development
PORT=5000
PORT_FALLBACK_RANGE=10

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/ebook-marketplace
MONGODB_TEST_URI=mongodb://localhost:27017/ebook-marketplace-test

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Resend Email Configuration (OTP)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=your-email@example.com

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_UPLOAD_PRESET=your-cloudinary-upload-preset

# Stripe Configuration (for payments)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLIC_KEY=your-stripe-public-key

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# Admin Configuration
ADMIN_EMAIL=admin@ebook-marketplace.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_SIGNUP_EMAIL=abdullah116632@gmail.com
