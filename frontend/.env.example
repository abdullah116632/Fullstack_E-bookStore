# Frontend API configuration
# Primary backend URL
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Comma-separated fallback backend URLs to try automatically if primary is down
NEXT_PUBLIC_API_FALLBACK_URLS=http://localhost:5001/api/v1,http://localhost:5002/api/v1

# Meta/Facebook Pixel ID
NEXT_PUBLIC_FB_PIXEL_ID=your_facebook_pixel_id_here
